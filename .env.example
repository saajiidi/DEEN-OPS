# Copy this file to .streamlit/secrets.toml and fill in your values.
# This is a TOML file, not a .env file — Streamlit reads secrets from .streamlit/secrets.toml.

[woocommerce]
url = "https://your-store.com"
consumer_key = "ck_your_consumer_key"
consumer_secret = "cs_your_consumer_secret"

[pathao]
base_url = "https://courier-api.pathao.com"
client_id = "your_client_id"
client_secret = "your_client_secret"
username = "your_email@example.com"
password = "your_password"

[llm]
openrouter_key = ""
gemini_key = ""
groq_key = ""

# Optional: Google OIDC authentication
# [auth]
# redirect_uri = "https://your-app.streamlit.app/oauth2callback"
# cookie_secret = "random-secret-string"
#
# [auth.google]
# client_id = "your-google-client-id.apps.googleusercontent.com"
# client_secret = "your-google-client-secret"
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
